#!/usr/bin/env python3
"""
Management tools for YAML translation files.

A directory holds the translations for a single module/component,
as one yaml file per language, ie, ru.yaml for russian.

Usually one of the languages is considered the reference one, usually 'en'.

YAML's contain a dictionary where keys are the ids to refer them.
Nested dictionaries are interpreted as namespaces.

A different multilingual yaml format is often used for transfers.
It contains structures ID->lang->text.
"""


import typer
from pathlib import Path
from ruamel.yaml import YAML
from collections import OrderedDict
from typer import echo, style

app = typer.Typer(
    help=__doc__,
    invoke_without_command=True,
)

# ------------------ message helpers ------------------

def step(text: str):
    """Informational step message."""
    echo(style(f"🔹 {text}", fg="blue"))

def success(text: str):
    """Success message."""
    echo(style(f"✅ {text}", fg="green"))

def warn(text: str):
    """Warning message."""
    echo(style(f"⚠️ {text}", fg="yellow"))

def error(text: str):
    """Error message (non-fatal)."""
    echo(style(f"❌ {text}", fg="red"))

def fail(text: str):
    """Fatal error: show message and exit."""
    error(text)
    raise typer.Exit(1)


@app.callback()
def main(ctx: typer.Context):
    if ctx.invoked_subcommand is None:
        typer.echo(ctx.get_help())
        raise typer.Exit()


# ------------------ YAML machinery ------------------

yaml = YAML(typ="rt")
yaml.indent(mapping=2, sequence=4, offset=2)
yaml.width = 10**9
yaml.preserve_quotes = True

def existing_languages(directory: Path) -> set[str]:
    return { f.stem for f in collect_yaml_files_from_dir(directory)}

def collect_files(paths):
    files = set()
    if not paths:
        paths = ["."]

    for p in paths:
        p = Path(p)
        if p.is_dir():
            files.update(p.glob("*.yml"))
            files.update(p.glob("*.yaml"))
        elif p.suffix in [".yml", ".yaml"]:
            files.add(p)

    return sorted(files)

def collect_yaml_files_from_dir(directory: Path) -> list[Path]:
    """Collect all YAML files (.yml and .yaml) in a directory."""
    if not directory.is_dir():
        fail(f"{directory} is not a directory")
    files = list(directory.glob("*.yml")) + list(directory.glob("*.yaml"))
    return sorted(files)

def lang_file(directory: Path, lang: str, fallback_extension: str = ".yaml") -> Path:
    """
    Determine the file to use for a given language in a directory.

    Whatever already exists, prioritizing yaml over yml
    If it does not exist, look for other languages in the directory
    and use their same extension, also prioritizing yaml over yml.
    """
    yaml_file = directory / f"{lang}.yaml"
    yml_file = directory / f"{lang}.yml"

    if yaml_file.exists():
        return yaml_file
    if yml_file.exists():
        return yml_file

    other_yaml = list(directory.glob("*.yaml"))
    if other_yaml:
        return yaml_file

    other_yml = list(directory.glob("*.yml"))
    if other_yml:
        return yml_file

    return directory / f"{lang}{fallback_extension}"


def flatten(d, parent_key="", sep="."):
    """Flattens id hierarchies into dotted ids in translation data"""
    items = {}
    for k, v in (d or {}).items():
        new_key = f"{parent_key}{sep}{k}" if parent_key else k
        if isinstance(v, dict):
            items.update(flatten(v, new_key, sep))
        else:
            items[new_key] = v
    return items


def unflatten(d, sep="."):
    """Unflattens dotted ids as hierarchy in translation data"""
    result = {}
    for key, value in d.items():
        parts = key.split(sep)
        target = result
        for part in parts[:-1]:
            target = target.setdefault(part, {})
        target[parts[-1]] = value
    return result


def load_flat(path: Path) -> dict:
    """Load YAML from path and return as flattened dict. Returns empty dict if file does not exist."""
    if not path.exists():
        return {}
    with path.open("r", encoding="utf-8") as f:
        data = yaml.load(f) or {}
    return flatten(data)

def load_flat_langs(directory: Path, languages: list[str]) -> dict[str, dict]:
    """
    Load flattened YAMLs for specified languages from a directory.
    If `languages` is None, all YAML files in the directory are loaded.
    """
    return {
        lang: load_flat(lang_file(directory, lang))
        for lang in languages
    }

def dump_flat(path: Path, flat_dict: dict):
    """Dump flattened dict into YAML at path, preserving hierarchy."""
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as f:
        yaml.dump(unflatten(flat_dict), f)

def detect_reference(files, ref_lang):
    for f in files:
        if f.stem == ref_lang:
            return f
    fail(f"Reference file '{ref_lang}.yaml' not found")


def apply_format(target_value, ref_value):
    return type(ref_value)(target_value)


def reorder(ref_data, data, context, add_missing, remove_extra):
    result = OrderedDict()

    # Ids in the reference language
    for key in ref_data:
        if key in data:
            result[key] = apply_format(data[key], ref_data[key])
        else:
            warn(f"{context}: missing {key}")
            if add_missing:
                result[key] = ""

    # Ids not in reference language
    extras = [k for k in data if k not in ref_data]
    if extras:
        warn(f"{context}: extra keys {', '.join(extras)}")
        if not remove_extra:
            for k in sorted(extras):
                result[k] = data[k]

    return result

@app.command()
def extract(
    input_dir: Path = typer.Argument(..., help="Directory with per-language YAML files"),
    ids: list[str] = typer.Argument(None, help="IDs or prefixes to extract (all if omitted)"),
    output_yaml: Path = typer.Argument(..., help="Output YAML file for extracted translations"),
):
    """
    Join translations in the directory into a multilingual file with flattened ids.
    """
    lang_flats = load_flat_langs(input_dir, existing_languages(input_dir))

    extracted: dict[str, dict[str, str]] = {}

    for lang, flat in lang_flats.items():
        for key, value in flat.items():
            if not ids or any(key == id_ or key.startswith(id_ + ".") for id_ in ids):
                extracted.setdefault(key, {})[lang] = value

    if not extracted:
        warn("No matching keys found in any language files")
        return

    # Write the extracted dictionary to the output YAML
    output_yaml.parent.mkdir(parents=True, exist_ok=True)
    with output_yaml.open("w", encoding="utf-8") as f:
        yaml.dump(extracted, f)

    success(f"Extracted {len(extracted)} keys into {output_yaml}")

@app.command()
def distribute(
    input_yaml: Path = typer.Argument(..., help="YAML with id -> lang -> translation"),
    output_dir: Path = typer.Argument(..., help="Directory with per language YAML translation files"),
):
    """
    Merge translations from a multilingual YAML into per-language YAML files.
    """
    with open(input_yaml, "r", encoding="utf-8") as f:
        data = yaml.load(f) or {}

    if not isinstance(data, dict):
        fail("Input YAML must be a dictionary")

    # Gather all languages present in the input
    languages = sorted({lang for translations in data.values() for lang in translations.keys()})
    if not languages:
        fail("No languages found in input YAML")

    # Load existing YAMLs for all languages into flattened dictionaries
    lang_flats = load_flat_langs(output_dir, languages)

    # Merge input data into each language's flattened dictionary
    for key, translations in data.items():
        for lang, text in translations.items():
            flat = lang_flats[lang]
            if key in flat:
                warn(f"{lang}: '{key}' already exists, overwriting")
            flat[key] = text

    # Write updated flattened dictionaries back to YAML files
    for lang, flat in lang_flats.items():
        dump_flat(output_dir / f"{lang}.yaml", flat)
        success(f"{lang}: updated {len(data)} keys")

    success("All translations distributed successfully!")


@app.command()
def sync(
    yamls: list[str] = typer.Argument(..., min=1,
        help="Directory containing translation yamls or specific yamls to process",
    ),
    ref: str = typer.Option("en", "--ref", help="Reference language"),
    add_missing: bool = typer.Option(False, "--add-missing",
        help="Adds missing ids from reference language with an empty string ready to fill",
    ),
    remove_extra: bool = typer.Option(False, "--remove-extra",
        help="Removes ids not in the reference language",
    ),
):
    """
    Applies the order and format of the reference language to the specified yaml files.

    Each directory is processed independently, caching reference files.
    """
    files = collect_files(yamls)
    if not files:
        fail("No YAML files found")

    ref_cache: dict[Path, dict] = {}

    for file in files:
        if file.stem == ref:
            continue

        step(f"Processing {file}...")
        directory = file.parent

        if directory not in ref_cache:
            ref_file = lang_file(directory, ref)
            if not ref_file.exists():
                fail(f"Reference file '{ref}.{ref_file.suffix[1:]}' not found in {directory}")
            ref_cache[directory] = load_flat(ref_file)

        ref_data = ref_cache[directory]

        data = load_flat(file)
        new_data = reorder(
            ref_data = ref_data,
            data = data,
            context = file,
            add_missing = add_missing,
            remove_extra = remove_extra,
        )
        dump_flat(file, new_data)
    success("Done")

@app.command()
def rename(
    path: Path = typer.Argument(..., help="Directory with YAML files"),
    old_id: str = typer.Argument(..., help="Old translation key"),
    new_id: str = typer.Argument(..., help="New translation key"),
):
    """
    Renames a text id in all the translation files
    """
    files = collect_yaml_files_from_dir(path)
    if not files:
        fail("No YAML files found")

    for file in sorted(files):
        step(f"Processing {file}...")
        flat = load_flat(file)

        if old_id not in flat:
            warn(f"{file.name}: '{old_id}' not found")
            continue

        if new_id in flat:
            warn(f"{file.name}: '{new_id}' already exists (overwriting)")

        flat[new_id] = flat[old_id]
        del flat[old_id]
        dump_flat(file, flat)
        success(f"{file.name}: '{old_id}' renamed to '{new_id}'")


@app.command()
def move(
    src_dir: Path = typer.Argument(..., help="Source translation directory"),
    dst_dir: Path = typer.Argument(..., help="Destination translation directory"),
    ids: list[str] = typer.Argument(..., help="IDs or prefixes to move"),
):
    """Move translation keys (possibly hierarchical) from source to destination module."""
    src_files = collect_yaml_files_from_dir(src_dir)
    if not src_files:
        fail("No YAML files found in source")

    dst_dir.mkdir(parents=True, exist_ok=True)

    for src_file in sorted(src_files):
        lang = src_file.stem
        dst_file = lang_file(dst_dir, lang, fallback_extension=src_dir.suffix)

        src_flat = load_flat(src_file)
        dst_flat = load_flat(dst_file)

        moved_any = False
        for move_id in ids:
            to_move = {k: v for k, v in src_flat.items()
                       if k == move_id or k.startswith(move_id + ".")}

            if not to_move:
                warn(f"{lang}: '{move_id}' not found in source")
                continue

            for k, v in to_move.items():
                if k in dst_flat:
                    warn(f"{lang}: '{k}' already in destination (overwriting)")
                dst_flat[k] = v
                del src_flat[k]
                moved_any = True

        if not moved_any:
            warn(f"{lang}: no keys moved")
            continue

        dump_flat(dst_file, dst_flat)
        dump_flat(src_file, src_flat)
        success(f"{lang}: moved {ids} from {src_dir} to {dst_dir}")

@app.command()
def andaluh(
    path: Path = typer.Argument(..., help="Directory with translation YAML files"),
    overwrite: bool = typer.Option(False, "--overwrite",
        help="Overwrite existing translations in destination language",
    ),
):
    """
    Generate Andalûh ('and') translations from Spanish ('es') file.

    The use of 'and' code is an abuse of a seldomly used code for
    Papuan Anzu language until Andalûh gets its own.
    """
    import re
    import andaluh as andaluh_lib

    def protect_variables(text):
        if not isinstance(text, str):
            return text, []

        variables = []

        def replace_var(match):
            variables.append(match.group(0))
            return f"%%%{len(variables) - 1}%%%"

        protected = re.sub(r"\{[^}]+\}", replace_var, text)
        return protected, variables

    def restore_variables(text, variables):
        if not isinstance(text, str):
            return text

        for i, var in enumerate(variables):
            text = text.replace(f"%%%{i}%%%", var)
        return text

    def translate_value(value):
        if not isinstance(value, str):
            return value

        protected, variables = protect_variables(value)
        translated = andaluh_lib.epa(protected)
        return restore_variables(translated, variables)

    if not path.is_dir():
        fail("Path must be a directory")

    src_lang = "es"
    dst_lang = "and"

    src_file = lang_file(path, src_lang)
    if not src_file.exists():
        fail(f"Source language '{src_lang}' not found in {path}")

    dst_file = lang_file(path, dst_lang)

    step(f"Source: {src_file}")
    step(f"Destination: {dst_file}")

    src_flat = load_flat(src_file)
    dst_flat = load_flat(dst_file)

    updated = 0
    skipped = 0

    for key, value in src_flat.items():
        if key in dst_flat:
            if not overwrite:
                warn(f"{dst_lang}: '{key}' already exists, skipping")
                skipped += 1
                continue
            warn(f"{dst_lang}: '{key}' overwritten")

        dst_flat[key] = translate_value(value)
        updated += 1

    if "language_code" in dst_flat:
        dst_flat["language_code"] = dst_lang
    if "language_name" in dst_flat:
        dst_flat["language_name"] = "Andalûh"

    dump_flat(dst_file, dst_flat)

    success(f"{dst_lang}: {updated} keys updated, {skipped} skipped")


if __name__ == "__main__":
    app()
