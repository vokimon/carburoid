#!/usr/bin/env python3
import os
import shutil
import subprocess
import sys
import json
import urllib.request
import re
import typer
import osmium
from pathlib import Path
from typing import Optional


app = typer.Typer()


SCRIPT_DIR = Path(__file__).parent.resolve()
GH_REPO = "https://github.com/graphhopper/graphhopper.git"
GH_DIR = SCRIPT_DIR / "graphhopper"
DATA_DIR = SCRIPT_DIR / "graphhopper-data"
OSM_DIR = DATA_DIR / "osm"
GRAPHS_DIR = DATA_DIR / "graphs"
GRAPHHOPPER_VERSION = '11.0'
OSM_URL_TEMPLATE = "https://download.geofabrik.de/{region}-latest.osm.pbf"
GEOFABRIK_INDEX_URL = "https://download.geofabrik.de/index-v1.json"


class Collector(osmium.SimpleHandler):
    def __init__(self):
        super().__init__()
        self.accepted_way_ids = set()
        self.used_node_ids = set()
        self.allowed_highways = {
            "motorway",
            "trunk",
            "primary",
            "secondary",
            "tertiary",
            "unclassified",
            "residential",
            "service",
            "living_street",
            "track"
        }

    def way(self, w):
        hw = w.tags.get("highway")
        if not hw or hw not in self.allowed_highways:
            return
        if w.tags.get("access") == "no":
            return
        if w.tags.get("motorcar") == "no":
            return
        self.accepted_way_ids.add(w.id)
        for nr in w.nodes:
            self.used_node_ids.add(nr.ref)


class Writer(osmium.SimpleHandler):
    def __init__(self, writer, collector):
        super().__init__()
        self.writer = writer
        self.collector = collector
        self.keep_tags = {
            "highway",
            "access",
            "motorcar",
            "oneway",
            "junction",
            "maxspeed",
        }

    def node(self, n):
        if n.id in self.collector.used_node_ids:
            self.writer.add_node(n)

    def way(self, w):
        if w.id not in self.collector.accepted_way_ids:
            return
        clean_tags = {k: v for k, v in w.tags if k in self.keep_tags}
        # Reconstruct way WITH id and original node refs
        new_way = w.replace(
            tags=clean_tags,
        )
        self.writer.add_way(new_way)

    def relation(self, r):
        pass  # skip


def filter_osm_routes(input_file, output_file):
    output_file.unlink(missing_ok=True)
    collector = Collector()
    collector.apply_file(str(input_file), locations=False)

    # Pass 2: write nodes + cleaned ways
    with osmium.SimpleWriter(str(output_file)) as writer:
        handler = Writer(writer, collector)
        handler.apply_file(str(input_file), locations=True)


def validate_iso_code(code: str) -> str:
    if not re.fullmatch(r"[a-z]{2}", code.lower()):
        typer.echo(f"❌ Invalid ISO code: '{code}'. Must be 2 lowercase letters (e.g., 'es', 'fr').", err=True)
        raise typer.Exit(code=1)
    return code.lower()

def get_geofabrik_url(country_code: str) -> str:
    """Resolve country code to Geofabrik PBF URL using official index."""
    country_code = country_code.lower()

    with urllib.request.urlopen(GEOFABRIK_INDEX_URL) as response:
        index = json.load(response)

    # Build map of supported countries
    supported = {}
    for entry in index["features"]:
        props = entry["properties"]
        print(props)
        cc = props.get("id")
        if not cc: continue
        url = props.get("urls", {}).get("pbf")
        if not url: continue
        supported[cc] = url

    if country_code in supported:
        print(supported[country_code])
        return supported[country_code]

    # Not found → show helpful error
    typer.echo(f"❌ Country code '{country_code}' not available in Geofabrik.", err=True)
    typer.echo("✅ Supported countries (ISO 3166-1 alpha-2):", err=True)
    
    # Sort by name for readability
    sorted_countries = sorted(supported.keys())
    typer.echo(f"{', '.join(sorted_countries)}")
    
    raise ValueError(f"Unsupported country: {country_code}")


def run(cmd: list[str], cwd: Path | None = None):
    typer.echo(f"▶️ Running: {' '.join(cmd)}")
    result = subprocess.run(cmd, cwd=cwd, check=True)
    return result


def ensure_setup_done() -> Path:
    """
    Ensure GraphHopper is set up.
    Returns the path to the JAR to use for routing.
    """
    # 1. Check for pre-built JAR
    prebuilt_jar = SCRIPT_DIR / "graphhopper-cli.jar"
    if prebuilt_jar.exists():
        return prebuilt_jar

    # 2. Check for built-from-source JAR
    built_jars = list((GH_DIR / "web" / "target").glob("graphhopper-web-*-jar-with-dependencies.jar"))
    if built_jars:
        return built_jars[0]  # take first match

    # 3. Not set up
    typer.echo("❌ GraphHopper is not set up.", err=True)
    typer.echo("👉 Run: ./tools/gh_prep.py setup [--version VERSION]", err=True)
    raise typer.Exit(code=1)

def download_to(url: str, path: Path):
    typer.echo(f"📥 Downloading {url} to {path}...")
    try:
        urllib.request.urlretrieve(url, path)
    except Exception as e:
        typer.echo(f"❌ Failed to download: {e}", err=True)
        raise typer.Exit(code=1)
    typer.echo(f"✅ Saved to {path}")



@app.command()
def setup(version: str = typer.Option("11.0", help="GraphHopper version (e.g., '11.0', '10.0', or 'git')")):
    """Set up GraphHopper: download pre-built JAR or build from source."""
    if version == "git":
        # Build from source
        if GH_DIR.exists():
            typer.echo("GraphHopper already cloned.")
        else:
            run(["git", "clone", "--depth=1", GH_REPO, str(GH_DIR)])
        run(["mvn", "clean", "install", "-DskipTests"], cwd=GH_DIR)
        typer.echo("✅ Built GraphHopper from source.")
    else:
        # Download pre-built JAR
        jar_path = SCRIPT_DIR / "graphhopper-cli.jar"
        if jar_path.exists():
            typer.echo("✅ GraphHopper JAR already downloaded.")
            return

        # Validate version format (optional)
        url = f"https://repo1.maven.org/maven2/com/graphhopper/graphhopper-web/{version}/graphhopper-web-{version}.jar"
        typer.echo(f"📥 Downloading GraphHopper {version} from {url}...")
        download_to(url, jar_path)

@app.command()
def compute_ch(country_code: str):
    """Build Contraction Hierarchy graph for a country."""
    country_code = country_code.lower()
    pbf_path = OSM_DIR / f"{country_code}.osm.pbf"
    if not pbf_path.exists():
        typer.echo("❌ OSM file missing. Run 'download' first.", err=True)
        raise typer.Exit(code=1)

    filtered_path = OSM_DIR / f"{country_code}-filtered.osm.pbf"
    filter_osm_routes(
        input_file=pbf_path,
        output_file=filtered_path,
    )

    graph_dir = GRAPHS_DIR / country_code
    graph_dir.mkdir(parents=True, exist_ok=True)

    # Get JAR from setup
    jar_path = ensure_setup_done()
    config_path = graph_dir / "config.yml"
    download_to("https://raw.githubusercontent.com/graphhopper/graphhopper/11.x/config-example.yml", config_path)
    config_lines = config_path.read_text().splitlines()
    patched_config = []
    for line in config_lines:
        if line.startswith("  datareader.file:"):
            patched_config.append(f'  datareader.file: {filtered_path.resolve()}')
        elif line.startswith("  graph.location:"):
            patched_config.append(f'  graph.location: {graph_dir.resolve()}')
            patched_config.append(f'  graph.include_geometry: false')
            patched_config.append(f'  datareader.preferred_language: ""')
            patched_config.append(f'  graph.store_empty_names: true')
        else:
            patched_config.append(line)


    config_path.write_text("\n".join(patched_config))


    typer.echo(f"⚙️ Building CH graph for {country_code} using {jar_path.name}...")
    run([
        "java", "-Xmx16g", "-jar", str(jar_path),
        "import",
        str(config_path)
    ])


@app.command()
def download(
    region: str = typer.Argument(..., help="Geofabrik region ID (e.g., 'spain', 'france')"),
):
    """Download OSM PBF for a country using Geofabrik's index."""
    try:
        url = get_geofabrik_url(region)
    except ValueError as e:
        typer.echo(f"❌ {e}", err=True)
        raise typer.Exit(code=1)

    OSM_DIR.mkdir(parents=True, exist_ok=True)
    output = OSM_DIR / f"{region.lower()}.osm.pbf"

    if output.exists():
        typer.echo(f"✅ Already downloaded: {output}")
        return

    typer.echo(f"📥 Downloading {region} from {url}")
    urllib.request.urlretrieve(url, output)
    typer.echo(f"💾 Saved to {output}")

@app.command()
def install(
    region: str = typer.Argument(..., help="Geofabrik region ID (e.g., 'spain', 'france')"),
    iso: str = typer.Argument(..., help="ISO 3166-1 alpha-2 code (e.g., 'es', 'fr')"),
    module: str = typer.Option("app", help="Android module name"),
    source_set: str = typer.Option("main", help="Source set (e.g., main, debug)")
):
    """Copy built graph to Android assets."""
    iso = iso.lower()
    validate_iso_code(iso)
    src = GRAPHS_DIR / region
    dst = Path(module) / "src" / source_set / "assets" / "routing" / iso

    if not src.exists():
        typer.echo(f"❌ Graph not found. Run 'compute-ch {region}' first.", err=True)
        raise typer.Exit(code=1)

    dst.parent.mkdir(parents=True, exist_ok=True)
    if dst.exists():
        shutil.rmtree(dst)
    shutil.copytree(src, dst)
    typer.echo(f"📦 Installed graph to {dst}")

@app.command()
def all(
    region: str = typer.Argument(..., help="Geofabrik region ID (e.g., 'spain', 'france')"),
    iso: str = typer.Argument(..., help="ISO 3166-1 alpha-2 code (e.g., 'es', 'fr')"),
):
    """Download, compute CH, and install in one command."""
    download(region)
    compute_ch(region)
    install(region, iso)

if __name__ == "__main__":
    app()
