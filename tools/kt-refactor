#!/usr/bin/env python3
"""kt-refactor: A general Kotlin refactoring tool."""
import re
import shutil
from pathlib import Path
import typer

app = typer.Typer(
    name="kt-refactor",
    help="A general Kotlin refactoring tool.",
    no_args_is_help=True,
)

def fail(reason: str):
    """Print error message and exit."""
    typer.echo(f"❌ {reason}", err=True)
    raise typer.Exit(1)

def success(goal: str):
    """Print success message."""
    typer.echo(f"✅ {goal}", err=True)

def warn(message: str):
    """Print warning message without exiting."""
    typer.echo(f"⚠️  {message}", err=True)

def read_content(path: Path) -> str:
    """Read file content with UTF-8 encoding."""
    return path.read_text(encoding='utf-8')


def write_content(path: Path, content: str) -> None:
    """Write file content with UTF-8 encoding."""
    path.write_text(content, encoding='utf-8')


def package_from_source(file_path: Path) -> str:
    """Extract package declaration from Kotlin/Java file."""
    content = read_content(file_path)
    for line in content.splitlines():
        line = line.strip()
        if line.startswith('package '):
            pkg = line[8:].rstrip(';').strip()
            return pkg
    return ""


def package_from_path(dir_path: Path) -> str:
    """Extract package name from directory path containing java/ or kotlin/."""
    dir_str = str(dir_path)
    if 'java/' in dir_str:
        pkg_path = dir_str.split('java/', 1)[1]
    elif 'kotlin/' in dir_str:
        pkg_path = dir_str.split('kotlin/', 1)[1]
    else:
        fail("Target directory should contain 'java/' or 'kotlin/' path")
    return pkg_path.replace('/', '.').rstrip('.')


def find_source_files() -> list[Path]:
    """Find all .kt and .java files under app/src, excluding .git and build."""
    files = []
    src_dir = Path('app/src')
    if not src_dir.exists():
        return []
    for ext in ['*.kt', '*.java']:
        for file in src_dir.rglob(ext):
            if '.git' in str(file):
                continue
            if '/build/' in str(file):
                continue
            files.append(file)
    return files


def symbol_in_list(symbol: str, symbol_list: list[str]) -> bool:
    """Check if symbol is in list using space-padded substring match."""
    padded_list = ' ' + ' '.join(symbol_list) + ' '
    padded_symbol = f' {symbol} '
    return padded_symbol in padded_list


def is_source_a_file(source: str) -> bool:
    """Check if source is a file path or FQN."""
    return '.kt' in source or '.java' in source or '/' in source


def build_update_patterns(old_fqn: str) -> tuple[str, str]:
    """Build regex patterns for updating FQN references."""
    escaped_old_fqn = re.escape(old_fqn)
    word_boundary = r'(?<![.\w])'
    word_boundary_end = r'(?![.\w])'

    fqn_pattern = f'{word_boundary}{escaped_old_fqn}{word_boundary_end}'
    import_pattern = rf'import\s+{escaped_old_fqn}{word_boundary_end}'

    return fqn_pattern, import_pattern


def update_file_content(
    file: Path,
    old_fqn: str,
    new_fqn: str,
    symbol: str,
    old_pkg: str,
) -> bool:
    """Update FQN references in a single file. Returns True if file was modified."""
    content = read_content(file)
    file_pkg = package_from_source(file)

    fqn_pattern, import_pattern = build_update_patterns(old_fqn)
    import_new = f'import {new_fqn}'

    has_import_statement = re.search(import_pattern, content) is not None
    has_fqn_references = re.search(fqn_pattern, content) is not None
    needs_import_insertion = (file_pkg == old_pkg) and import_new not in content

    has_unqualified_refs = False
    if needs_import_insertion:
        unqualified_pattern = r'(?<![.\w])' + re.escape(symbol) + r'(?![.\w])'
        has_unqualified_refs = re.search(unqualified_pattern, content) is not None

    if not (has_import_statement or has_fqn_references or has_unqualified_refs):
        return False

    if has_fqn_references:
        content = re.sub(fqn_pattern, new_fqn, content)

    if has_import_statement:
        content = re.sub(import_pattern, import_new, content)
    elif has_unqualified_refs:
        package_line = re.search(r'^package\s+[\w.]+;', content, flags=re.MULTILINE)
        if package_line:
            insert_pos = package_line.end()
            content = content[:insert_pos] + f'\n{import_new}' + content[insert_pos:]

    write_content(file, content)
    return True


def move_and_update_package(source_file: Path, target_file: Path, current_pkg: str, target_pkg: str) -> None:
    """Move file and update its package declaration."""
    target_file.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(source_file), str(target_file))

    escaped_current = re.escape(current_pkg)
    content = read_content(target_file)
    content = re.sub(f'^package {escaped_current}', f'package {target_pkg}', content, flags=re.MULTILINE)
    write_content(target_file, content)


def cleanup_empty_directories(source_file: Path) -> None:
    """Remove empty parent directories after moving a file."""
    source_dir = source_file.parent
    if source_dir.is_dir() and not any(source_dir.iterdir()):
        typer.echo(f"🧹 Removing empty directory: {source_dir}")
        try:
            while source_dir.is_dir() and not any(source_dir.iterdir()):
                source_dir.rmdir()
                source_dir = source_dir.parent
        except OSError as e:
            warn(f"Could not remove empty directory: {e}")


def collect_symbols_to_update(source_basename: str, target_basename: str, symbols: list[str]) -> list[str]:
    """Collect all symbols that need reference updates."""
    symbols_to_update = [source_basename]
    typer.echo(f"🔍 Including original symbol: {source_basename}")

    if target_basename != source_basename:
        symbols_to_update.append(target_basename)
        typer.echo(f"🔍 Including new symbol (rename): {target_basename}")

    for symbol in symbols:
        if not symbol_in_list(symbol, symbols_to_update):
            symbols_to_update.append(symbol)
            typer.echo(f"🔍 Including explicit symbol: {symbol}")

    return symbols_to_update


def update_symbol_references(symbol: str, current_pkg: str, target_pkg: str) -> None:
    """Update all references to a symbol from old package to new package."""
    old_fqn = f"{current_pkg}.{symbol}"
    new_fqn = f"{target_pkg}.{symbol}"

    typer.echo("")
    typer.echo(f"🔄 Updating symbol references for: {symbol}")
    typer.echo(f"   Old: {old_fqn}")
    typer.echo(f"   New: {new_fqn}")

    for file in find_source_files():
        update_file_content(file, old_fqn, new_fqn, symbol, current_pkg)


def update_fqn_references(old_fqn: str, new_fqn: str) -> None:
    """Update all references from old FQN to new FQN."""
    typer.echo("")
    typer.echo(f"🔄 Updating references:")
    typer.echo(f"   Old: {old_fqn}")
    typer.echo(f"   New: {new_fqn}")

    for file in find_source_files():
        update_file_content(file, old_fqn, new_fqn, "", "")


def verify_remaining_refs(fqns: list[str]) -> bool:
    """Check for remaining references to old FQNs."""
    found_refs = False
    for old_fqn in fqns:
        for file in find_source_files():
            content = read_content(file)
            if old_fqn not in content:
                continue
            found_refs = True
            typer.echo(f"{file}:{old_fqn}")
    return found_refs


def handle_file_mode(source: str, target: str, symbols: list[str]) -> None:
    """Handle file move/rename mode."""
    source_file = Path(source)
    target_path = Path(target)

    if not source_file.is_file():
        fail(f"Source file not found: {source_file}")

    current_pkg = package_from_source(source_file)
    if not current_pkg:
        fail(f"No package declaration found in: {source_file}")

    target_is_explicit_file = '.kt' in str(target_path) or '.java' in str(target_path)

    target_file = target_path if target_is_explicit_file else target_path / source_file.name
    target_pkg = package_from_path(target_file.parent)

    typer.echo("📁 Moving/Renaming file:")
    typer.echo(f"  From: {source_file}")
    if target_is_explicit_file:
        typer.echo(f"  To:   {target_file} (rename)")
        typer.echo(f"  Old symbol: {source_file.stem}")
        typer.echo(f"  New symbol: {target_file.stem}")
    else:
        typer.echo(f"  To:   {target_file}")
    typer.echo(f"  Current package: {current_pkg}")
    typer.echo(f"  Target package:  {target_pkg}")
    typer.echo("")

    move_and_update_package(source_file, target_file, current_pkg, target_pkg)
    cleanup_empty_directories(source_file)

    success("File moved/renamed successfully!")

    symbols_to_update = collect_symbols_to_update(source_file.stem, target_file.stem, symbols)

    for symbol in symbols_to_update:
        update_symbol_references(symbol, current_pkg, target_pkg)

    typer.echo("")
    typer.echo("🔍 Verification:")
    fqns_to_check = [f"{current_pkg}.{s}" for s in symbols_to_update]
    if not verify_remaining_refs(fqns_to_check):
        success("No remaining references found for moved symbols!")

    warn(f"{target_file.name} may have compilation errors due to references to {current_pkg}")


def handle_symbol_mode(source: str, target: str) -> None:
    """Handle symbol-only FQN to FQN mode."""
    old_fqn = source
    new_fqn = target

    if '.' not in old_fqn or '.' not in new_fqn:
        fail("Invalid FQN format. Both arguments must contain dots.")

    typer.echo("🔄 Symbol-only update:")
    typer.echo(f"  Old: {old_fqn}")
    typer.echo(f"  New: {new_fqn}")
    typer.echo("")

    update_fqn_references(old_fqn, new_fqn)

    success("Symbol references updated!")

    typer.echo("")
    typer.echo("🔍 Verification:")
    if not verify_remaining_refs([old_fqn]):
        success("No remaining references found!")


@app.command("move")
def move(
    source: str = typer.Argument(..., help="Source file path or old fully-qualified name"),
    target: str = typer.Argument(..., help="Target directory/file path or new fully-qualified name"),
    symbols: list[str] = typer.Argument(None, help="Additional symbols to update besides the one named like the file"),
):
    """
    Moves kotlin artifacts between packages or modules adapting imports.

    Usage:
      File move:   kt-refactor move <source_file> <target_dir> [symbols...]
      File rename: kt-refactor move <source_file> <target_file.kt> [symbols...]
      Symbol only: kt-refactor move <old_fully_qualified_name> <new_fully_qualified_name>

    Examples:
      kt-refactor move app/src/main/java/net/canvoki/carburoid/ui/settings/LinkPreference.kt app/src/main/java/net/canvoki/shared/component/preferences/ OtherSymbol ExtraSymbol
      kt-refactor move app/src/main/java/net/canvoki/carburoid/ui/settings/OldName.kt app/src/main/java/net/canvoki/shared/component/preferences/NewName.kt
      kt-refactor move net.canvoki.carburoid.ui.settings.LinkPreference net.canvoki.shared.component.preferences.LinkPreference
    """
    if symbols is None:
        symbols = []

    if is_source_a_file(source):
        handle_file_mode(source, target, symbols)
    else:
        handle_symbol_mode(source, target)

    typer.echo("")
    typer.echo("💡 Done! Review changes with: git diff")


if __name__ == "__main__":
    app()
