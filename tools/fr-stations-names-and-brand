#!/usr/bin/env python
import requests
from bs4 import BeautifulSoup
import sys
from consolemsg import step
from pathlib import Path

# curl "https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/prix-des-carburants-en-france-flux-instantane-v2/exports/json?limit=200&select=exclude(services),exclude(prix),exclude(rupture),exclude(horaires)" | jq . - | grep \"id\" | sed s/.*\:// | sed s/,// > fr-ideess.tsv 


def get_brand_info(station_id: int) -> dict | None:
    url = f"https://www.prix-carburants.gouv.fr/station/{station_id}"
    headers = {
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36"
    }
    
    try:
        step(f"Retrieving {url}")
        response = requests.get(url, headers=headers, timeout=10)
        response.raise_for_status()
    except Exception as e:
        print(f"Error fetching station {station_id}: {e}", file=sys.stderr)
        return None

    soup = BeautifulSoup(response.text, 'html.parser')

    details = soup.find('div', id='details_pdv')
    if not details:
        print("Details section not found", file=sys.stderr)
        return None

    # 1. Título: primer <p> dentro de #details_pdv
    title_brand = None
    first_p = details.find('p')
    if first_p:
        title_brand = first_p.get_text(strip=True)

    # 2. Marque : buscar <strong> con texto "Marque :" y tomar el siguiente nodo de texto
    marque_brand = None
    marque_label = details.find('strong', string=lambda text: text and "Marque" in text.strip())
    if marque_label:
        # El siguiente nodo hermano inmediato debería ser un NavigableString
        next_node = marque_label.next_sibling
        if next_node and hasattr(next_node, 'strip'):
            marque_brand = next_node.strip()

    return {
        "id": station_id,
        "title_brand": title_brand,
        "marque_brand": marque_brand,
        "url": url
    }

def available_ids():
    import requests
    response = requests.get(
        "https://data.economie.gouv.fr/"
            "api/explore/v2.1/catalog/"
            "datasets/prix-des-carburants-en-france-flux-instantane-v2/"
            "exports/json?limit=-1"
            "&select=exclude(services),exclude(prix),exclude(rupture),exclude(horaires)"
    )
    import json
    Path("lala.json").write_text(response.text)
    content = json.loads(response.text)
    return {str(station['id']) for station in content}

def processed_ids():
    content = Path("app/src/main/assets/fr-stations-brands-names.tsv").read_text()
    return {
        line.split('\t')[0].strip()
        for line in content.splitlines()
    }

def process_batch(nids):
    allids = available_ids()
    doneids = processed_ids()
    to_process = (allids - doneids)
    step(f"{len(doneids)} of {len(allids)}, remaining {len(to_process)}")
    for i, id in zip(range(nids), to_process):
        process_id(id)

def process_id(id):
    info = get_brand_info(id)
    if info:
        print(f"{info['id']}\t{info['marque_brand']}\t{info['title_brand']}")
    else:
        print("Failed to extract data", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("Usage: python extract_both.py <n_stations>")
        sys.exit(1)
    #process_id(sys.argv[1])
    process_batch(int(sys.argv[1]))
